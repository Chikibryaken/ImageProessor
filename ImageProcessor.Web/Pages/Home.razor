@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<h1>Обработка изображений</h1>

@if (_error != null)
{
    <div class="error-box" role="alert">@_error</div>
}

<div class="controls">
    <InputFile OnChange="OnFileSelected" accept=".png,.jpg,.jpeg" disabled="@_busy" />

    <select @bind="_filter" @bind:after="OnFilterChanged" disabled="@_busy" class="filter-select">
        <option value="invert">Инверсия</option>
        <option value="grayscale">Оттенки серого</option>
        <option value="sepia">Сепия</option>
        <option value="blur">Размытие</option>
        <option value="sharpen">Резкость</option>
        <option value="brightness">Яркость</option>
        <option value="contrast">Контраст</option>
        <option value="pixelate">Пикселизация</option>
        <option value="flip-horizontal">Отражение по горизонтали</option>
        <option value="flip-vertical">Отражение по вертикали</option>
    </select>

    @if (_filter == "blur")
    {
        <label class="blur-strength">
            Сила: <span>@_blurStrength</span>
            <input type="range" min="1" max="20" @bind="_blurStrength" @bind:event="oninput" />
        </label>
    }

    @if (_filter == "brightness")
    {
        <label class="intensity-label">
            Яркость: <span>@_intensity.ToString("F1", CultureInfo.InvariantCulture)</span>
            <input type="range" min="0.1" max="3.0" step="0.1"
                   @bind="_intensity" @bind:event="oninput"
                   @bind:culture="CultureInfo.InvariantCulture" />
        </label>
    }

    @if (_filter == "contrast")
    {
        <label class="intensity-label">
            Контраст: <span>@_intensity.ToString("F1", CultureInfo.InvariantCulture)</span>
            <input type="range" min="0.1" max="3.0" step="0.1"
                   @bind="_intensity" @bind:event="oninput"
                   @bind:culture="CultureInfo.InvariantCulture" />
        </label>
    }

    @if (_filter == "pixelate")
    {
        <label class="intensity-label">
            Размер блока: <span>@((int)_intensity)</span>
            <input type="range" min="5" max="50" step="5"
                   @bind="_intensity" @bind:event="oninput"
                   @bind:culture="CultureInfo.InvariantCulture" />
        </label>
    }

    <button class="btn-apply" @onclick="ApplyFilter"
            disabled="@(_originalBytes == null || _busy)">
        @(_busy ? "Обработка..." : "Применить фильтр")
    </button>
</div>

@if (_originalDataUrl != null || _resultBytes != null)
{
    <div class="images-row">
        @if (_originalDataUrl != null)
        {
            <figure>
                <img src="@_originalDataUrl" alt="Оригинал" />
                <figcaption>Оригинал</figcaption>
            </figure>
        }
        @if (_resultBytes != null)
        {
            <figure>
                <img src="@_resultDataUrl" alt="Результат" />
                <figcaption>@_appliedFilterLabel</figcaption>
                <button class="btn-download" @onclick="Download">Скачать результат</button>
            </figure>
        }
    </div>
}

@code {
    private const long MaxBytes = 10 * 1024 * 1024;

    private static readonly HashSet<string> AllowedMime = ["image/png", "image/jpeg"];

    private static readonly Dictionary<string, string> FilterLabels = new()
    {
        ["invert"]           = "Инверсия",
        ["grayscale"]        = "Оттенки серого",
        ["sepia"]            = "Сепия",
        ["blur"]             = "Размытие",
        ["sharpen"]          = "Резкость",
        ["brightness"]       = "Яркость",
        ["contrast"]         = "Контраст",
        ["pixelate"]         = "Пикселизация",
        ["flip-horizontal"]  = "Отражение по горизонтали",
        ["flip-vertical"]    = "Отражение по вертикали",
    };

    private IBrowserFile? _file;
    private byte[]? _originalBytes;
    private string? _originalMimeType;
    private string? _originalDataUrl;

    private byte[]? _resultBytes;
    private string? _resultDataUrl;
    private string? _appliedFilterLabel;

    private string _filter = "invert";
    private int _blurStrength = 5;
    private float _intensity = 1.0f;
    private bool _busy;
    private string? _error;

    private void OnFilterChanged()
    {
        _intensity = _filter == "pixelate" ? 10f : 1.0f;
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _originalDataUrl = null;
        _resultBytes = null;
        _resultDataUrl = null;
        _originalBytes = null;
        _file = null;

        var file = e.File;
        var mime = file.ContentType.ToLowerInvariant();

        if (!AllowedMime.Contains(mime))
        {
            _error = $"Неподдерживаемый формат «{file.ContentType}». Выберите PNG или JPEG.";
            return;
        }

        using var stream = file.OpenReadStream(MaxBytes);
        _originalBytes = new byte[file.Size];
        await stream.ReadExactlyAsync(_originalBytes);

        _file = file;
        _originalMimeType = mime;
        _originalDataUrl = $"data:{mime};base64,{Convert.ToBase64String(_originalBytes)}";
    }

    private async Task ApplyFilter()
    {
        if (_originalBytes == null || _file == null) return;

        _busy = true;
        _error = null;
        _resultBytes = null;
        _resultDataUrl = null;

        try
        {
            using var content = new MultipartFormDataContent();

            var part = new ByteArrayContent(_originalBytes);
            part.Headers.ContentType = new(_originalMimeType!);
            content.Add(part, "file", _file.Name);
            content.Add(new StringContent(_filter), "filter");

            if (_filter == "blur")
                content.Add(new StringContent(_blurStrength.ToString()), "blurstrength");

            if (_filter is "brightness" or "contrast" or "pixelate")
                content.Add(new StringContent(
                    _intensity.ToString(CultureInfo.InvariantCulture)), "intensity");

            var response = await Http.PostAsync("api/images/process", content);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                _error = $"Ошибка {(int)response.StatusCode}: {body}";
                return;
            }

            _resultBytes = await response.Content.ReadAsByteArrayAsync();
            _resultDataUrl = $"data:image/png;base64,{Convert.ToBase64String(_resultBytes)}";
            _appliedFilterLabel = FilterLabels.GetValueOrDefault(_filter, _filter);
        }
        catch (Exception ex)
        {
            _error = $"Ошибка запроса: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Download()
    {
        if (_resultBytes == null) return;
        var fileName = $"{_filter}.png";
        await JS.InvokeVoidAsync("imageInterop.downloadFile", fileName, _resultBytes);
    }
}
